#!/usr/bin/env bash
#
# cw — launch the containerized Claude workflow for ONE ribose project.
#
# Usage:
#   cd ribose/<org>/<repo> && cw ["task description"]   # derive repo from $PWD
#   cw <org>/<repo> ["task description"]                 # explicit repo
#
# Everything under /work is read-only inside the container EXCEPT the target
# repo, which is overlaid read-write below. Worktrees are created inside it at
# .claude/worktrees/<slug>, so all writes stay confined to the single project.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"      # .../ribose/claude-container
RIBOSE_ROOT="$(cd "${COMPOSE_DIR}/.." && pwd)"     # .../ribose
COMPOSE_FILE="${COMPOSE_DIR}/compose.yml"

die() { echo "cw: $*" >&2; exit 1; }

# --- resolve the target repo (org/repo) -------------------------------------
target=""
if [[ $# -ge 1 && "$1" == */* && -d "${RIBOSE_ROOT}/$1" ]]; then
  target="$1"; shift
elif [[ "${PWD}/" == "${RIBOSE_ROOT}/"* ]]; then
  rel="${PWD#"${RIBOSE_ROOT}"/}"
  target="$(printf '%s' "$rel" | cut -d/ -f1-2)"
else
  die "run from inside a ribose project dir, or pass <org>/<repo> explicitly.
     e.g.  cd ${RIBOSE_ROOT}/relaton/relaton-bib && cw \"add retry logic\""
fi

org="${target%%/*}"
repo="${target#*/}"
[[ -n "$org" && -n "$repo" && "$org" != "$target" ]] \
  || die "could not resolve <org>/<repo> from '${target}'."
[[ "$org" != "claude-container" ]] \
  || die "claude-container is the tooling dir, not a project to work on."
[[ -d "${RIBOSE_ROOT}/${target}/.git" || -f "${RIBOSE_ROOT}/${target}/.git" ]] \
  || die "${target} is not a git repo (${RIBOSE_ROOT}/${target})."

task="$*"

# GitHub auth for the container: the host stores its gh token in the macOS keyring
# (not in the mounted ~/.config/gh), so pull it out and pass it as GH_TOKEN, which
# compose forwards. The container's git is configured to use it for HTTPS pushes.
export GH_TOKEN="${GH_TOKEN:-$(gh auth token 2>/dev/null || true)}"
[[ -z "${GH_TOKEN}" ]] && echo "cw: warning — no GH_TOKEN (run 'gh auth login'); pushes will fail." >&2

# --- assemble the claude command --------------------------------------------
# Start in PLAN mode (harness-enforced: Claude cannot edit until you approve a
# plan) so it can never start coding before discussing the plan. Pair it with
# --allow-dangerously-skip-permissions so that, after you approve, you can run
# the implementation autonomously without per-edit prompts (approve the plan with
# "accept edits", or Shift+Tab to the bypass mode it adds to the cycle).
cmd=(claude --permission-mode plan --allow-dangerously-skip-permissions)
if [[ -n "$task" ]]; then
  cmd+=("/feature ${task}")
fi

echo "cw: project=${target}  (writes confined to this repo, incl. its .claude/worktrees)" >&2
[[ -n "$task" ]] && echo "cw: task=${task}" >&2

# Only the target repo is mounted read-write. Worktrees live inside it at
# .claude/worktrees/<slug>, so they need no separate mount — they ride the repo's
# RW bind mount, which also keeps all writes physically confined to this project.
exec docker compose -f "${COMPOSE_FILE}" run --rm \
  -w "/work/${target}" \
  -v "${RIBOSE_ROOT}/${target}:/work/${target}" \
  dev "${cmd[@]}"

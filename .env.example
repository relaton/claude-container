# Copy to `.env` (auto-loaded by docker compose) and fill what you need.
# `gh` and git are authenticated via mounted host configs, so you usually only
# need the gem token here. Set a Claude auth fallback only if you don't want to
# run `claude login` inside the container.

# Private gems (GitHub Packages). Already exported on the host in this setup;
# set it here too if your shell doesn't export it to docker compose.
# BUNDLE_RUBYGEMS__PKG__GITHUB__COM=ghp_xxx

# Claude Code auth fallback (pick ONE) — instead of `claude login`:
#   long-lived token from `claude setup-token`:
# CLAUDE_CODE_OAUTH_TOKEN=
#   or a raw API key:
# ANTHROPIC_API_KEY=

# GitHub token fallback (only if you don't mount ~/.config/gh):
# GH_TOKEN=

# Match the container user to your host user if bind-mount ownership matters
# (Docker Desktop for Mac usually handles this automatically):
# HOST_UID=501
# HOST_GID=20

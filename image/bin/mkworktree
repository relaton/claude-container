#!/usr/bin/env bash
#
# mkworktree <name> [branch] — create an isolated git worktree under the repo's
# own .claude/worktrees/ that is reachable from BOTH the container and the host.
#
# <name> is a conventional, type-prefixed branch name describing the work, e.g.
#   feat/add-http-retry   fix/null-deref   chore/bump-deps   docs/readme
# The worktree dir mirrors it (.claude/worktrees/<name>) and the branch defaults
# to the same — so the directory and branch read identically.
#
# The container ships git >= 2.48, so we use NATIVE relative worktree links
# (`git worktree add --relative-paths`): both the forward .git link and the
# repo-side backlink are stored relative, so they resolve whether the repo is
# seen at /work/... (container) or /Users/... (host). No path mismatch, no
# manual link surgery, and no assumption about how deep the worktree sits — git
# computes the relative path. (The container's global config also sets
# worktree.useRelativePaths=true, so a bare `git worktree add` is host-reachable
# too — this helper just adds the convenience of a fixed location, a sensible
# branch name, and a local exclude so the dir never shows as untracked.)
#
# Result: ribose/<org>/<repo>/.claude/worktrees/<name>  — review it from the host.

set -euo pipefail

name="${1:?usage: mkworktree <name> [branch]   (e.g. mkworktree feat/add-http-retry)}"
branch="${2:-${name}}"

# Resolve the MAIN repo root even if we're invoked from a subdir: the common git
# dir is <root>/.git, so its parent is the repo root. (--path-format is git 2.31+.)
main_root="$(cd "$(dirname "$(git rev-parse --path-format=absolute --git-common-dir)")" && pwd)"
cd "$main_root"

# Keep the worktrees dir from ever showing as untracked or getting committed.
# Uses .git/info/exclude (local-only) — does NOT touch the repo's tracked .gitignore.
exclude="$(git rev-parse --git-path info/exclude)"
mkdir -p "$(dirname "$exclude")"
grep -qxF '/.claude/worktrees/' "$exclude" 2>/dev/null \
  || echo '/.claude/worktrees/' >> "$exclude"

# Native relative links (git 2.48+): usable from the container AND the host.
# --relative-paths is explicit so this works even without the global config
# (e.g. if mkworktree is ever run on the host). git creates intermediate dirs
# for a slashed name (feat/...), so the dir mirrors the branch.
git worktree add --relative-paths ".claude/worktrees/${name}" -b "${branch}"

echo "mkworktree: created .claude/worktrees/${name}  (branch ${branch})"
echo "mkworktree: host path -> <repo>/.claude/worktrees/${name}"
echo "mkworktree: next -> cd .claude/worktrees/${name}"
